<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Mercedes S-class</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">
</head>

<body style="">

<nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container">
        <a class="navbar-brand" href="/">S-Class</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" href="/register">
                        Регистрация
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/login">
                        Вход
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/?logout">
                        Выход
                    </a>
                </li>


                <li class="nav-item">
                <div style="
                    width: 1px;
                    height: 40px;
                    background: grey;
                "></div>
                </li>

{% for age in ages %}
                <li class="nav-item">
                    <a class="nav-link {{ current_uri == '/ages/' ~ age.age ? 'active' : '' }}" href="/ages/{{ age.age }}">
                        {{ age.translation}}
                    </a>
                </li>
{% endfor %}

                <li class="nav-item">
                <div style="
                    width: 1px;
                    height: 40px;
                    background: grey;
                "></div>
                </li>

                <li class="nav-item">
                    <a class="nav-link {{ current_uri == '/search' ? 'active' : '' }}" href="/search">
                        Поиск
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ current_uri == '/add' ? 'active' : '' }}" href="/add">
                        Добавить автомобиль
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ current_uri == '/add_age' ? 'active' : '' }}" href="/add_age">
                        Добавить тип
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div style="
    display: flex;
    gap: 10px
">
<div style="width: 80%;">
{% block content %}
{% endblock %}
</div>
<div style="max-height: 100vh; width: calc(20% - 15px); padding: 20px; border-left: 1px solid grey;">
{% for page in pages_history %}
    <div style="background: #fafafa; padding: 5px; margin-bottom: 10px">
        <a href="{{page}}">
            {{page}}
        </a>
    </div>
{% endfor %}
</div>
</div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-kenU1KFdBIe4zVF0s0G1M5b4hcpxyD9F7jL+jjXkk+Q2h455rYXK/7HAuoJl+0I4" crossorigin="anonymous"></script>
</body>
</html>